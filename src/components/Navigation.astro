---
const views = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'historia', label: 'Historia' },
  { id: 'teclados', label: 'Teclados' },
  { id: 'proceso', label: 'Proceso' },
  { id: 'maderas', label: 'Maderas' },
  { id: 'specs', label: 'Specs' },
  { id: 'contacto', label: 'Contacto' },
];
---

<nav class="nav-bar" aria-label="Navegación principal">
  <div class="nav-bar__inner">
    {views.map((view, i) => (
      <button
        data-view-index={i}
        class:list={['nav-key', { 'nav-key--active': i === 0 }]}
        aria-label={`Ir a ${view.label}`}
      >
        {i === 0 ? (
          <svg class="h-4 w-4" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <polygon points="16,18 6,13 6,23 16,28" fill="var(--color-digital-500)" opacity="0.85"/>
            <polygon points="16,18 26,13 26,23 16,28" fill="var(--color-human-500)" opacity="0.85"/>
            <polygon points="16,8 6,13 16,18 26,13" fill="var(--color-natural-500)" opacity="0.75"/>
          </svg>
        ) : (
          <span>{view.label}</span>
        )}
      </button>
    ))}

    <div class="nav-separator"></div>

    <button
      data-theme-toggle
      class="nav-key nav-key--theme"
      aria-label="Cambiar tema"
    >
      <span class="theme-icon-sun" aria-hidden="true">☀</span>
      <span class="theme-icon-moon" aria-hidden="true">☾</span>
    </button>

    <button
      data-dev-toggle
      class="nav-key nav-key--dev"
      aria-label="Activar modo desarrollador"
    >
      &lt;/&gt;
    </button>
  </div>
</nav>
