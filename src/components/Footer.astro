---
const year = new Date().getFullYear();
---

<footer class="border-t border-charcoal-500 bg-charcoal-700 px-6 py-12 lg:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none">
            <polygon points="16,10 6,16 16,22" fill="var(--color-digital-500)" opacity="0.9"/>
            <polygon points="16,10 26,16 16,22" fill="var(--color-human-500)" opacity="0.9"/>
            <polygon points="6,16 16,10 26,16 16,22" fill="var(--color-natural-500)" opacity="0.7"/>
            <rect x="12" y="4" width="8" height="7" rx="1" fill="var(--color-ivory-100)" opacity="0.95"/>
          </svg>
          <span class="font-semibold text-ivory-100 tracking-tight">Tecleados</span>
        </div>
        <p class="text-sm text-sage-400 leading-relaxed max-w-xs">
          Teclados mecánicos artesanales que fusionan lo digital, lo natural y lo humano. Hechos a mano en Argentina.
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-16">
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-widest text-sage-300">Navegar</h4>
          <ul class="space-y-2">
            <li><a href="#teclados" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Teclados</a></li>
            <li><a href="#proceso" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Proceso</a></li>
            <li><a href="#maderas" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Maderas</a></li>
            <li><a href="#comunidad" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Comunidad</a></li>
            <li><a href="#firmware" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Firmware</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-widest text-sage-300">Social</h4>
          <ul class="space-y-2">
            <li><a href="#" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Instagram</a></li>
            <li><a href="#" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">Discord</a></li>
            <li><a href="#" class="text-sm text-sage-400 transition-colors hover:text-ivory-100">GitHub</a></li>
          </ul>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-3 text-xs font-semibold uppercase tracking-widest text-sage-300">Contacto</h4>
        <a href="mailto:hola@tecleados.com" class="font-[var(--font-mono)] text-sm text-digital-400 transition-colors hover:text-digital-300">
          hola@tecleados.com
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-charcoal-500 pt-8 md:flex-row">
      <p class="font-[var(--font-mono)] text-xs text-sage-500">
        v1.0.0 // hecho a mano en argentina // {year}
      </p>
      <p class="text-xs text-sage-500">
        &copy; {year} Tecleados. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
