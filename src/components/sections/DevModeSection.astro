---
---

<section id="specs" class="relative overflow-hidden bg-charcoal-800 py-[length:var(--space-section)]">
  <!-- Scanline overlay -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-digital-500) 2px, var(--color-digital-500) 3px); background-size: 100% 4px;">
  </div>

  <div class="mx-auto max-w-4xl px-6 lg:px-10">
    <!-- Section Header -->
    <div class="mb-12 lg:mb-16" data-animate="fade-up">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-3 w-3 rounded-full bg-natural-500"></div>
        <div class="h-3 w-3 rounded-full bg-human-500"></div>
        <div class="h-3 w-3 rounded-full bg-digital-500"></div>
      </div>
      <p class="mb-3 font-[var(--font-mono)] text-[length:var(--text-mono-sm)] uppercase tracking-[0.2em] text-digital-500">
        &gt; para los que quieren saber más
      </p>
      <h2 class="text-[length:var(--text-h1)] font-semibold leading-tight text-ivory-100">
        Especificaciones
      </h2>
    </div>

    <!-- Code Block -->
    <div class="relative overflow-hidden rounded-xl border border-charcoal-500/50 bg-charcoal-900" data-animate="fade-up">
      <!-- Title Bar -->
      <div class="flex items-center gap-2 border-b border-charcoal-600 px-4 py-3">
        <div class="h-2.5 w-2.5 rounded-full bg-human-500/60"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-human-400/40"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-natural-500/40"></div>
        <span class="ml-3 font-[var(--font-mono)] text-[11px] text-sage-500">tecleados.config.ts</span>
      </div>

      <!-- Code Content -->
      <div class="overflow-x-auto p-6 lg:p-8">
        <pre class="font-[var(--font-mono)] text-[length:var(--text-mono-sm)] leading-7"><code><span class="text-sage-500">// Configuración base de un teclado Tecleados</span>
<span class="text-digital-400">export</span> <span class="text-digital-400">const</span> <span class="text-ivory-200">keyboard</span> <span class="text-sage-400">=</span> <span class="text-sage-400">&#123;</span>

  <span class="text-natural-400">layout</span><span class="text-sage-400">:</span>     <span class="text-human-300">"ISO-ES"</span> <span class="text-sage-500">| "ANSI"</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">switches</span><span class="text-sage-400">:</span>   <span class="text-human-300">"Cherry MX"</span> <span class="text-sage-500">| "Gateron" | "Kailh"</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">keycaps</span><span class="text-sage-400">:</span>    <span class="text-human-300">"PBT Double-Shot"</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">hotswap</span><span class="text-sage-400">:</span>    <span class="text-digital-300">true</span><span class="text-sage-400">,</span>

  <span class="text-natural-400">case</span><span class="text-sage-400">:</span> <span class="text-sage-400">&#123;</span>
    <span class="text-natural-400">material</span><span class="text-sage-400">:</span>    <span class="text-human-300">"Madera Nativa Argentina"</span><span class="text-sage-400">,</span>
    <span class="text-natural-400">finish</span><span class="text-sage-400">:</span>      <span class="text-human-300">"Aceitado a Mano"</span><span class="text-sage-400">,</span>
    <span class="text-natural-400">species</span><span class="text-sage-400">:</span>     <span class="text-sage-400">[</span><span class="text-human-300">"Lenga"</span><span class="text-sage-400">,</span> <span class="text-human-300">"Algarrobo"</span><span class="text-sage-400">,</span> <span class="text-human-300">"Quebracho"</span><span class="text-sage-400">,</span> <span class="text-human-300">"Guatambú"</span><span class="text-sage-400">],</span>
    <span class="text-natural-400">weight</span><span class="text-sage-400">:</span>      <span class="text-human-300">"450g - 650g"</span><span class="text-sage-400">,</span>
  <span class="text-sage-400">&#125;,</span>

  <span class="text-natural-400">connectivity</span><span class="text-sage-400">:</span> <span class="text-human-300">"USB-C"</span> <span class="text-sage-500">| "Bluetooth 5.0"</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">firmware</span><span class="text-sage-400">:</span>     <span class="text-human-300">"QMK / VIA Compatible"</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">rgb</span><span class="text-sage-400">:</span>          <span class="text-digital-300">true</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">nkro</span><span class="text-sage-400">:</span>         <span class="text-digital-300">true</span><span class="text-sage-400">,</span>

  <span class="text-sage-500">// Cada teclado es único</span>
  <span class="text-natural-400">serialNumber</span><span class="text-sage-400">:</span> <span class="text-human-300">`TC-$&#123;Date.now()&#125;`</span><span class="text-sage-400">,</span>
  <span class="text-natural-400">madeIn</span><span class="text-sage-400">:</span>       <span class="text-human-300">"Buenos Aires, Argentina"</span> <span class="text-digital-500">🇦🇷</span><span class="text-sage-400">,</span>

<span class="text-sage-400">&#125;</span> <span class="text-digital-400">satisfies</span> <span class="text-digital-300">Tecleados.Config</span><span class="text-sage-400">;</span></code></pre>
      </div>
    </div>

    <!-- Features Grid Below Code -->
    <div class="mt-12 grid gap-6 sm:grid-cols-3" data-animate="stagger">
      <div class="rounded-lg border border-charcoal-600 bg-charcoal-700/50 p-5">
        <p class="mb-1 font-[var(--font-mono)] text-xs text-digital-400">firmware</p>
        <p class="text-sm font-medium text-ivory-200">QMK + VIA</p>
        <p class="mt-1 text-xs text-sage-400">Remapeo total de teclas. Open source.</p>
      </div>
      <div class="rounded-lg border border-charcoal-600 bg-charcoal-700/50 p-5">
        <p class="mb-1 font-[var(--font-mono)] text-xs text-natural-400">material</p>
        <p class="text-sm font-medium text-ivory-200">Madera Nativa</p>
        <p class="mt-1 text-xs text-sage-400">Sustentable. Cada pieza irrepetible.</p>
      </div>
      <div class="rounded-lg border border-charcoal-600 bg-charcoal-700/50 p-5">
        <p class="mb-1 font-[var(--font-mono)] text-xs text-human-400">artesanía</p>
        <p class="text-sm font-medium text-ivory-200">Hecho a Mano</p>
        <p class="mt-1 text-xs text-sage-400">Acabado manual. Control de calidad individual.</p>
      </div>
    </div>
  </div>
</section>
