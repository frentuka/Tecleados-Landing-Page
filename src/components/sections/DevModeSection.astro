---
const groups = [
  {
    pillar: 'Digital',
    borderColor: 'border-digital-500/20',
    labelColor: 'text-digital-400',
    accentBg: 'bg-digital-500/5',
    dotColor: 'bg-digital-500',
    specs: [
      { label: 'Firmware',       value: 'DF-ONE (ESP-IDF v5.5)' },
      { label: 'Conectividad',   value: 'USB-C HID · BLE 5.0 (9 perfiles)' },
      { label: 'Escaneo',        value: '1200 Hz · NKRO real (bitmap 32B)' },
      { label: 'Capas / Macros', value: '4 capas · 64 macros (256 eventos)' },
      { label: 'Configurador',   value: 'Web (WebHID · React 19)' },
    ],
  },
  {
    pillar: 'Natural',
    borderColor: 'border-natural-500/20',
    labelColor: 'text-natural-400',
    accentBg: 'bg-natural-500/5',
    dotColor: 'bg-natural-500',
    specs: [
      { label: 'Material',    value: 'Madera nativa argentina' },
      { label: 'Especies',    value: 'Lenga · Algarrobo · Quebracho · Guatambú' },
      { label: 'Acabado',     value: 'Aceitado a mano' },
      { label: 'Peso',        value: '450 g – 650 g' },
      { label: 'Sustentable', value: 'Productores certificados' },
    ],
  },
  {
    pillar: 'Humano',
    borderColor: 'border-human-500/20',
    labelColor: 'text-human-400',
    accentBg: 'bg-human-500/5',
    dotColor: 'bg-human-500',
    specs: [
      { label: 'Switches', value: 'Cherry MX · Gateron · Kailh' },
      { label: 'Keycaps',  value: 'PBT Double-Shot' },
      { label: 'Hotswap',  value: 'Sí, sin soldar' },
      { label: 'Origen',   value: 'Buenos Aires, Argentina' },
      { label: 'Serie',    value: 'Edición limitada, numerada' },
    ],
  },
];
---

<section class="view view--hidden" id="specs">
  <!-- Decorative grid -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.025]" aria-hidden="true"
    style="background-image: linear-gradient(var(--color-sage-400) 1px, transparent 1px), linear-gradient(90deg, var(--color-sage-400) 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 lg:px-10">
    <div class="mx-auto w-full max-w-6xl">
      <!-- Header -->
      <div data-enter data-anim="data-header" data-anim-duration="0.6s" class="mb-3 sm:mb-6 lg:mb-8">
        <p class="t-text-muted mb-1 font-[var(--font-mono)] text-[length:var(--text-mono-sm)] uppercase tracking-[0.2em] sm:mb-2">
          Para los que quieren saber más
        </p>
        <h2 class="text-[length:var(--text-h1)] font-semibold leading-tight">
          Especificaciones
        </h2>
      </div>

      <!-- Spec Groups -->
      <div class="grid grid-cols-3 gap-2 sm:gap-4 lg:gap-5">
        {groups.map((group, gi) => (
          <div
            data-enter
            data-anim={gi === 0 ? 'slam-left' : gi === 1 ? 'slam-top' : 'slam-right'}
            data-anim-duration="0.7s"
            class:list={[
              'rounded-lg border p-2 sm:rounded-xl sm:p-5 lg:p-6',
              group.borderColor,
              group.accentBg,
            ]}
          >
            <!-- Group header -->
            <div class="mb-2 flex items-center gap-1 sm:mb-4 sm:gap-2">
              <span class:list={['h-1.5 w-1.5 rounded-full sm:h-2 sm:w-2', group.dotColor]}></span>
              <span class:list={['font-[var(--font-mono)] text-[9px] uppercase tracking-[0.1em] sm:text-xs sm:tracking-[0.2em]', group.labelColor]}>
                {group.pillar}
              </span>
            </div>

            <!-- Spec rows -->
            <ul class="space-y-1.5 sm:space-y-3">
              {group.specs.map((spec) => (
                <li class="t-border flex flex-col gap-0 border-b pb-1.5 last:border-0 last:pb-0 sm:gap-0.5 sm:pb-3">
                  <span class:list={['font-[var(--font-mono)] text-[8px] uppercase tracking-[0.1em] sm:text-[10px] sm:tracking-[0.15em]', group.labelColor]}>
                    {spec.label}
                  </span>
                  <span class="t-text-2 text-[10px] font-light leading-tight sm:text-[length:var(--text-small)] sm:leading-snug">
                    {spec.value}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Bottom note -->
      <p data-enter data-anim="terminal-blink-in" data-anim-duration="0.85s" class="t-text-muted mt-3 text-center font-[var(--font-mono)] text-[9px] sm:mt-5 sm:text-[length:var(--text-mono-sm)]">
        // specs pueden variar por modelo
      </p>
    </div>
  </div>

  <span class="dev-annotation absolute bottom-16 left-4">// view: specs | groups: 3</span>
</section>
