---
---

<section class="view view--active" id="inicio">
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: linear-gradient(var(--color-sage-400) 1px, transparent 1px), linear-gradient(90deg, var(--color-sage-400) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 text-center">
    <!-- Isometric Cube -->
    <div data-enter data-anim="spring-pop" data-anim-duration="0.85s">
      <svg viewBox="0 0 200 200" class="h-32 w-32 drop-shadow-2xl lg:h-44 lg:w-44" xmlns="http://www.w3.org/2000/svg">
        <polygon points="100,100 30,65 30,135 100,170" fill="var(--color-digital-500)" opacity="0.85"/>
        <polygon points="100,100 30,65 30,135 100,170" fill="url(#pixelPatternDigital)" opacity="0.15"/>
        <polygon points="100,100 170,65 170,135 100,170" fill="var(--color-human-500)" opacity="0.85"/>
        <polygon points="100,100 170,65 170,135 100,170" fill="url(#pixelPatternHuman)" opacity="0.1"/>
        <polygon points="100,30 30,65 100,100 170,65" fill="var(--color-natural-500)" opacity="0.8"/>
        <line x1="100" y1="100" x2="100" y2="170" stroke="var(--color-charcoal-600)" stroke-width="0.5" opacity="0.3"/>
        <line x1="100" y1="100" x2="30" y2="65" stroke="var(--color-ivory-100)" stroke-width="0.5" opacity="0.15"/>
        <line x1="100" y1="100" x2="170" y2="65" stroke="var(--color-ivory-100)" stroke-width="0.5" opacity="0.1"/>
        <g transform="translate(100, 65)">
          <polygon points="0,-20 -18,-10 0,0 18,-10" fill="var(--color-ivory-200)" />
          <polygon points="-18,-10 -18,-4 0,6 0,0" fill="var(--color-ivory-400)" />
          <polygon points="18,-10 18,-4 0,6 0,0" fill="var(--color-ivory-300)" />
          <polygon points="0,-20 -14,-12 0,-4 14,-12" fill="var(--color-ivory-100)" />
          <text x="0" y="-9" text-anchor="middle" font-family="var(--font-mono)" font-size="7" font-weight="600" fill="var(--color-charcoal-400)">T</text>
        </g>
        <defs>
          <pattern id="pixelPatternDigital" patternUnits="userSpaceOnUse" width="8" height="8">
            <rect width="4" height="4" fill="var(--color-digital-300)" opacity="0.3"/>
            <rect x="4" y="4" width="4" height="4" fill="var(--color-digital-300)" opacity="0.3"/>
          </pattern>
          <pattern id="pixelPatternHuman" patternUnits="userSpaceOnUse" width="6" height="6">
            <rect width="3" height="3" fill="var(--color-human-300)" opacity="0.2"/>
            <rect x="3" y="3" width="3" height="3" fill="var(--color-human-300)" opacity="0.2"/>
          </pattern>
        </defs>
      </svg>
    </div>

    <h1 data-enter data-anim="spring-pop" data-anim-duration="0.85s" class="mt-6 text-[length:var(--text-hero)] font-semibold leading-none tracking-tight lg:mt-8">
      Tecleados
    </h1>

    <p data-enter data-anim="glitch-slide" data-anim-duration="0.65s" class="t-text-2 mt-3 max-w-lg text-[length:var(--text-body)] font-light leading-relaxed lg:mt-4">
      Teclados mecánicos artesanales que fusionan lo digital, lo natural y lo humano.
    </p>

    <div data-enter data-anim="glitch-slide" data-anim-duration="0.6s" class="mt-6 flex items-center gap-2 lg:mt-8">
      <span class="font-[var(--font-mono)] text-[length:var(--text-mono-sm)] text-digital-500">$</span>
      <div class="relative">
        <p class="t-text-muted font-[var(--font-mono)] text-[length:var(--text-mono-sm)] invisible" aria-hidden="true">Crea algo que valga la pena estar vivo e interactúa con ello que te hace ser.</p>
        <p id="typewriter" class="t-text-muted font-[var(--font-mono)] text-[length:var(--text-mono-sm)] absolute inset-0"
          data-text="Crea algo que valga la pena estar vivo e interactúa con ello que te hace ser."></p>
      </div>
      <span class="inline-block h-4 w-[2px] bg-digital-500" style="animation: cursorBlink 1s infinite;"></span>
    </div>

  </div>

  <span class="dev-annotation absolute bottom-16 left-4">// view: inicio | mode: single-page</span>
</section>


<script>
  const el = document.getElementById('typewriter');
  if (el) {
    const text = el.dataset.text || '';
    let i = 0;
    function type() {
      if (i < text.length) {
        el!.textContent += text.charAt(i);
        i++;
        setTimeout(type, 45 + Math.random() * 35);
      }
    }
    setTimeout(type, 800);
  }
</script>
