---
---

<section id="hero" class="relative flex min-h-screen items-center justify-center overflow-hidden bg-charcoal-600">
  <!-- Morphing Gradient Background -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="morphing-gradient-orb morphing-gradient-orb--digital absolute left-[20%] top-[30%] h-[500px] w-[500px] rounded-full opacity-[0.15] blur-[100px]"></div>
    <div class="morphing-gradient-orb morphing-gradient-orb--natural absolute right-[25%] top-[50%] h-[400px] w-[400px] rounded-full opacity-[0.12] blur-[100px]"></div>
    <div class="morphing-gradient-orb morphing-gradient-orb--human absolute left-[50%] bottom-[20%] h-[450px] w-[450px] rounded-full opacity-[0.10] blur-[100px]"></div>
  </div>

  <!-- Subtle grid overlay -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: linear-gradient(var(--color-sage-400) 1px, transparent 1px), linear-gradient(90deg, var(--color-sage-400) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center px-6 pb-24 text-center" data-animate="hero-cube">
    <!-- Isometric Cube -->
    <div class="mb-8 lg:mb-12">
      <svg
        viewBox="0 0 200 200"
        class="h-40 w-40 drop-shadow-2xl lg:h-56 lg:w-56"
        xmlns="http://www.w3.org/2000/svg"
      >
        <!-- Left face — Digital (Cyan) -->
        <polygon
          points="100,100 30,65 30,135 100,170"
          fill="var(--color-digital-500)"
          opacity="0.85"
        />
        <polygon
          points="100,100 30,65 30,135 100,170"
          fill="url(#pixelPatternDigital)"
          opacity="0.15"
        />

        <!-- Right face — Human (Warm Earth) -->
        <polygon
          points="100,100 170,65 170,135 100,170"
          fill="var(--color-human-500)"
          opacity="0.85"
        />
        <polygon
          points="100,100 170,65 170,135 100,170"
          fill="url(#pixelPatternHuman)"
          opacity="0.1"
        />

        <!-- Top face — Natural (Green) -->
        <polygon
          points="100,30 30,65 100,100 170,65"
          fill="var(--color-natural-500)"
          opacity="0.8"
        />

        <!-- Face edge highlights -->
        <line x1="100" y1="100" x2="100" y2="170" stroke="var(--color-charcoal-600)" stroke-width="0.5" opacity="0.3"/>
        <line x1="100" y1="100" x2="30" y2="65" stroke="var(--color-ivory-100)" stroke-width="0.5" opacity="0.15"/>
        <line x1="100" y1="100" x2="170" y2="65" stroke="var(--color-ivory-100)" stroke-width="0.5" opacity="0.1"/>

        <!-- Keycap centered on top face -->
        <g transform="translate(100, 65)">
          <!-- Keycap base (isometric) -->
          <polygon points="0,-20 -18,-10 0,0 18,-10" fill="var(--color-ivory-200)" />
          <!-- Keycap sides -->
          <polygon points="-18,-10 -18,-4 0,6 0,0" fill="var(--color-ivory-400)" />
          <polygon points="18,-10 18,-4 0,6 0,0" fill="var(--color-ivory-300)" />
          <!-- Keycap top surface -->
          <polygon points="0,-20 -14,-12 0,-4 14,-12" fill="var(--color-ivory-100)" />
          <!-- Keycap legend (T) -->
          <text x="0" y="-9" text-anchor="middle" font-family="var(--font-mono)" font-size="7" font-weight="600" fill="var(--color-charcoal-400)">T</text>
        </g>

        <!-- Pixel pattern definitions -->
        <defs>
          <pattern id="pixelPatternDigital" patternUnits="userSpaceOnUse" width="8" height="8">
            <rect width="4" height="4" fill="var(--color-digital-300)" opacity="0.3"/>
            <rect x="4" y="4" width="4" height="4" fill="var(--color-digital-300)" opacity="0.3"/>
          </pattern>
          <pattern id="pixelPatternHuman" patternUnits="userSpaceOnUse" width="6" height="6">
            <rect width="3" height="3" fill="var(--color-human-300)" opacity="0.2"/>
            <rect x="3" y="3" width="3" height="3" fill="var(--color-human-300)" opacity="0.2"/>
          </pattern>
        </defs>
      </svg>
    </div>

    <!-- Brand Name -->
    <h1 class="mb-4 text-[length:var(--text-hero)] font-semibold leading-none tracking-tight text-ivory-100 lg:mb-6">
      Tecleados
    </h1>

    <!-- Tagline -->
    <p class="mb-8 max-w-lg text-[length:var(--text-body)] font-light leading-relaxed text-sage-300">
      Teclados mecánicos artesanales que fusionan lo digital, lo natural y lo humano.
    </p>

    <!-- Mantra (Typewriter) -->
    <div class="flex items-center gap-2">
      <span class="text-digital-500 font-[var(--font-mono)] text-[length:var(--text-mono-sm)]">$</span>
      <p
        id="typewriter"
        class="font-[var(--font-mono)] text-[length:var(--text-mono-sm)] text-sage-400"
        data-text="Crea algo que valga la pena estar vivo e interactúa con ello que te hace ser."
      ></p>
      <span class="inline-block h-4 w-[2px] bg-digital-500" style="animation: cursorBlink 1s infinite;"></span>
    </div>

  </div>

  <!-- Scroll indicator (positioned relative to section, not content) -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" data-animate="fade-in">
    <div class="flex flex-col items-center gap-2">
      <span class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.2em] text-sage-500">scroll</span>
      <div class="h-8 w-[1px] bg-gradient-to-b from-sage-500 to-transparent"></div>
    </div>
  </div>

  <!-- Dev annotation -->
  <span class="dev-annotation absolute bottom-4 left-4">// section: hero | height: 100vh | bg: charcoal-600</span>
</section>

<style>
  .morphing-gradient-orb--digital {
    background: radial-gradient(circle, var(--color-digital-500), transparent 70%);
    animation: morphGradient1 25s ease-in-out infinite;
    mix-blend-mode: soft-light;
  }
  .morphing-gradient-orb--natural {
    background: radial-gradient(circle, var(--color-natural-500), transparent 70%);
    animation: morphGradient2 30s ease-in-out infinite;
    mix-blend-mode: soft-light;
  }
  .morphing-gradient-orb--human {
    background: radial-gradient(circle, var(--color-human-500), transparent 70%);
    animation: morphGradient3 28s ease-in-out infinite;
    mix-blend-mode: soft-light;
  }
</style>

<script>
  // Typewriter effect
  const el = document.getElementById('typewriter');
  if (el) {
    const text = el.dataset.text || '';
    let i = 0;
    function type() {
      if (i < text.length) {
        el!.textContent += text.charAt(i);
        i++;
        setTimeout(type, 45 + Math.random() * 35);
      }
    }
    // Start after a short delay
    setTimeout(type, 800);
  }
</script>
