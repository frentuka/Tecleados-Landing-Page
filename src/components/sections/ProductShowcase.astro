---
import { products } from '../../data/products';

const statusLabels: Record<string, { text: string; color: string }> = {
  disponible: { text: '● Disponible', color: 'text-natural-400' },
  proximamente: { text: '◐ Próximamente', color: 'text-human-400' },
  agotado: { text: '○ Agotado', color: 'text-sage-400' },
};

const woodColors: Record<string, string> = {
  Lenga: '#d4a574',
  Algarrobo: '#8b5e3c',
  Quebracho: '#6b2d1a',
  Guatambú: '#e8d5b7',
};
---

<section class="view view--hidden" id="teclados">
  <!-- Decorative wood grain texture -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: repeating-linear-gradient(90deg, var(--color-human-500) 0px, transparent 1px, transparent 30px); background-size: 31px 100%;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 lg:px-10">
    <div class="mx-auto w-full max-w-4xl">
      <div data-enter class="mb-6 text-center lg:mb-8">
        <p class="t-text-muted mb-2 font-[var(--font-mono)] text-[length:var(--text-mono-sm)] uppercase tracking-[0.2em]">
          Nuestros teclados
        </p>
        <h2 class="text-[length:var(--text-h1)] font-semibold leading-tight">
          Cada pieza, una historia
        </h2>
      </div>

      <div data-enter class="relative">
        <div id="product-carousel">
          {products.map((product, i) => (
            <div class={`product-slide ${i === 0 ? 'product-slide--active' : ''}`} data-slide={i}>
              <div class="grid gap-6 md:grid-cols-2 md:gap-8">
                <!-- Product Image (always dark — it's the product display area) -->
                <div class="relative overflow-hidden rounded-xl bg-gradient-to-br from-charcoal-500 to-charcoal-700 aspect-[4/3]">
                  <div class="absolute inset-0 rounded-xl" style={`box-shadow: inset 0 0 0 3px ${woodColors[product.wood] || '#888'}20;`}></div>
                  <div class="flex h-full items-center justify-center">
                    <svg viewBox="0 0 160 60" class="w-3/4 opacity-40">
                      <rect x="5" y="10" width="150" height="40" rx="6" fill="var(--color-human-700)" opacity="0.5"/>
                      <rect x="8" y="12" width="144" height="36" rx="4" fill="var(--color-human-800)" opacity="0.3"/>
                      {[0,1,2,3].map((row) => (
                        <>
                          {Array.from({length: 14 - row}).map((_, col) => (
                            <rect
                              x={10 + col * 10 + row * 3}
                              y={14 + row * 9}
                              width="8"
                              height="7"
                              rx="1"
                              fill="var(--color-ivory-300)"
                              opacity="0.15"
                            />
                          ))}
                        </>
                      ))}
                    </svg>
                  </div>
                  <div class="absolute top-3 right-3">
                    <span class={`inline-flex items-center rounded-full bg-charcoal-700/80 px-3 py-1 font-[var(--font-mono)] text-[10px] backdrop-blur-sm ${statusLabels[product.status].color}`}>
                      {statusLabels[product.status].text}
                    </span>
                  </div>
                </div>

                <!-- Product Info -->
                <div class="flex flex-col justify-center">
                  <div class="mb-2 flex items-center justify-between">
                    <h3 class="text-[length:var(--text-h2)] font-semibold">
                      {product.name}
                    </h3>
                    <span class="t-text-muted font-[var(--font-mono)] text-sm">
                      {product.price}
                    </span>
                  </div>
                  <p class="t-text-2 mb-4 text-[length:var(--text-body)] font-light leading-relaxed">
                    {product.description}
                  </p>
                  <div class="flex items-center gap-2">
                    <span class="inline-block h-3 w-3 rounded-full" style={`background-color: ${woodColors[product.wood] || '#888'};`}></span>
                    <span class="t-text-muted font-[var(--font-mono)] text-xs">{product.wood}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <button id="prev-product" class="carousel-arrow absolute -left-5 top-1/2 hidden -translate-y-1/2 md:flex" aria-label="Producto anterior">‹</button>
        <button id="next-product" class="carousel-arrow absolute -right-5 top-1/2 hidden -translate-y-1/2 md:flex" aria-label="Producto siguiente">›</button>
      </div>

      <div data-enter class="mt-6 flex items-center justify-center gap-2">
        {products.map((_, i) => (
          <button class={`carousel-dot ${i === 0 ? 'carousel-dot--active' : ''}`} data-dot={i} aria-label={`Ver producto ${i + 1}`}></button>
        ))}
        <div class="ml-4 flex gap-2 md:hidden">
          <button id="prev-product-mobile" class="carousel-arrow flex !w-8 !h-8 text-sm" aria-label="Anterior">‹</button>
          <button id="next-product-mobile" class="carousel-arrow flex !w-8 !h-8 text-sm" aria-label="Siguiente">›</button>
        </div>
      </div>
    </div>
  </div>

  <span class="dev-annotation absolute bottom-16 left-4">// view: teclados | carousel: {products.length} items</span>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-slide]');
  const dots = document.querySelectorAll<HTMLElement>('[data-dot]');
  let current = 0;

  function showSlide(index: number) {
    if (index < 0 || index >= slides.length) return;
    slides.forEach(s => s.classList.remove('product-slide--active'));
    dots.forEach(d => d.classList.remove('carousel-dot--active'));
    slides[index].classList.add('product-slide--active');
    dots[index].classList.add('carousel-dot--active');
    current = index;
  }

  document.getElementById('prev-product')?.addEventListener('click', () => showSlide(current - 1 >= 0 ? current - 1 : slides.length - 1));
  document.getElementById('next-product')?.addEventListener('click', () => showSlide((current + 1) % slides.length));
  document.getElementById('prev-product-mobile')?.addEventListener('click', () => showSlide(current - 1 >= 0 ? current - 1 : slides.length - 1));
  document.getElementById('next-product-mobile')?.addEventListener('click', () => showSlide((current + 1) % slides.length));

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => showSlide(i));
  });

  // Keyboard (up/down arrows dispatched by view engine)
  const section = document.getElementById('teclados');
  section?.addEventListener('view:internal-next', () => {
    showSlide((current + 1) % slides.length);
  });
  section?.addEventListener('view:internal-prev', () => {
    showSlide(current - 1 >= 0 ? current - 1 : slides.length - 1);
  });

  // Horizontal swipe
  const carousel = document.getElementById('product-carousel');
  if (carousel) {
    let startX = 0;
    let startY = 0;
    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const dx = startX - e.changedTouches[0].clientX;
      const dy = startY - e.changedTouches[0].clientY;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0) showSlide((current + 1) % slides.length);
        else showSlide(current - 1 >= 0 ? current - 1 : slides.length - 1);
      }
    }, { passive: true });
  }
</script>
