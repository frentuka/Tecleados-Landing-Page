---
import { processSteps } from '../../data/process-steps';
---

<section class="view view--hidden" id="proceso">
  <!-- Decorative grid -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.025]" aria-hidden="true"
    style="background-image: linear-gradient(var(--color-sage-500) 1px, transparent 1px), linear-gradient(90deg, var(--color-sage-500) 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 lg:px-10">
    <div class="mx-auto w-full max-w-4xl">
      <div data-enter data-anim="factory-header" data-anim-duration="0.55s" class="mb-8 text-center lg:mb-10">
        <p class="t-text-muted mb-2 font-[var(--font-mono)] text-[length:var(--text-mono-sm)] uppercase tracking-[0.2em]">
          El proceso
        </p>
        <h2 class="text-[length:var(--text-h1)] font-semibold leading-tight">
          De la madera a tus manos
        </h2>
      </div>

      <div data-enter data-anim="node-drop" data-anim-duration="0.7s" class="mb-8 flex items-center justify-center gap-1 sm:gap-2 lg:gap-3">
        {processSteps.map((step, i) => (
          <>
            <button
              class={`step-node ${i === 0 ? 'step-node--active' : ''}`}
              data-step-btn={i}
              aria-label={`Paso ${step.number}: ${step.title}`}
            >
              {step.number}
            </button>
            {i < processSteps.length - 1 && (
              <div class="step-connector"></div>
            )}
          </>
        ))}
      </div>

      <div data-enter data-anim="detail-blur-reveal" data-anim-duration="0.55s" class="mx-auto max-w-2xl text-center">
        {processSteps.map((step, i) => (
          <div class={`step-detail ${i === 0 ? 'step-detail--active' : ''}`} data-step-detail={i}>
            <h3 class="mb-3 text-[length:var(--text-h2)] font-semibold">
              {step.title}
            </h3>
            <p class="t-text-2 text-[length:var(--text-body)] font-light leading-relaxed">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <span class="dev-annotation absolute bottom-16 left-4">// view: proceso | steps: {processSteps.length}</span>
</section>

<script>
  const stepBtns = document.querySelectorAll<HTMLElement>('[data-step-btn]');
  const stepDetails = document.querySelectorAll<HTMLElement>('[data-step-detail]');

  let currentStep = 0;

  function goToStep(index: number) {
    if (index < 0 || index >= stepBtns.length || index === currentStep) return;
    stepBtns.forEach(b => b.classList.remove('step-node--active'));
    stepDetails.forEach(d => d.classList.remove('step-detail--active'));
    stepBtns[index].classList.add('step-node--active');
    stepDetails[index].classList.add('step-detail--active');
    currentStep = index;
  }

  stepBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => goToStep(i));
  });

  // Keyboard (up/down arrows dispatched by view engine)
  const section = document.getElementById('proceso');
  section?.addEventListener('view:internal-next', () => {
    goToStep(Math.min(currentStep + 1, stepBtns.length - 1));
  });
  section?.addEventListener('view:internal-prev', () => {
    goToStep(Math.max(currentStep - 1, 0));
  });

  // Horizontal swipe
  const proceso = document.getElementById('proceso');
  if (proceso) {
    let startX = 0;
    let startY = 0;
    proceso.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    }, { passive: true });
    proceso.addEventListener('touchend', (e) => {
      const dx = startX - e.changedTouches[0].clientX;
      const dy = startY - e.changedTouches[0].clientY;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0) goToStep(Math.min(currentStep + 1, stepBtns.length - 1));
        else goToStep(Math.max(currentStep - 1, 0));
      }
    }, { passive: true });
  }
</script>
