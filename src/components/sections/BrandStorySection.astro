---
---

<section id="historia" class="relative overflow-hidden bg-ivory-100 py-[length:var(--space-section)]">
  <!-- Paper texture overlay -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true"
    style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%224%22 height=%224%22><rect width=%224%22 height=%224%22 fill=%22%23a0a09b%22 opacity=%220.5%22/><rect width=%222%22 height=%222%22 fill=%22%23c9d1c9%22 opacity=%220.3%22/></svg>'); background-size: 4px 4px;">
  </div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-10">
    <div class="grid items-center gap-12 lg:grid-cols-5 lg:gap-20">
      <!-- Photo (3 cols) -->
      <div class="lg:col-span-3" data-animate="slide-left">
        <div class="relative overflow-hidden rounded-2xl bg-charcoal-200 aspect-[4/3]">
          <!-- Placeholder image with gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-human-700/40 via-natural-800/30 to-charcoal-600/60"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <!-- Pixel art desk scene placeholder -->
              <svg viewBox="0 0 120 80" class="h-32 w-48 mx-auto pixel-art opacity-60">
                <!-- Desk -->
                <rect x="10" y="50" width="100" height="4" fill="var(--color-human-500)" rx="1"/>
                <rect x="15" y="54" width="4" height="20" fill="var(--color-human-600)"/>
                <rect x="101" y="54" width="4" height="20" fill="var(--color-human-600)"/>
                <!-- Keyboard on desk -->
                <rect x="35" y="42" width="40" height="8" rx="2" fill="var(--color-ivory-300)"/>
                <rect x="37" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="41" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="45" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="49" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="53" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="57" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="61" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="65" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="69" y="43" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="37" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="41" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="45" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="49" y="46" width="3" height="2" fill="var(--color-digital-500)"/>
                <rect x="53" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="57" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="61" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="65" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <rect x="69" y="46" width="3" height="2" fill="var(--color-charcoal-300)"/>
                <!-- Coffee mug -->
                <rect x="82" y="40" width="10" height="10" rx="2" fill="var(--color-human-400)"/>
                <rect x="84" y="42" width="6" height="4" fill="var(--color-human-800)"/>
                <rect x="92" y="43" width="3" height="4" rx="1" fill="var(--color-human-400)"/>
                <!-- Plant -->
                <rect x="18" y="35" width="8" height="15" rx="2" fill="var(--color-natural-600)"/>
                <circle cx="22" cy="30" r="6" fill="var(--color-natural-400)" opacity="0.9"/>
                <circle cx="18" cy="28" r="4" fill="var(--color-natural-500)" opacity="0.8"/>
                <circle cx="26" cy="29" r="4" fill="var(--color-natural-300)" opacity="0.9"/>
                <!-- Monitor -->
                <rect x="40" y="14" width="30" height="22" rx="2" fill="var(--color-charcoal-500)"/>
                <rect x="42" y="16" width="26" height="16" fill="var(--color-charcoal-700)"/>
                <!-- Screen content - code lines -->
                <rect x="44" y="18" width="12" height="1" fill="var(--color-digital-500)" opacity="0.8"/>
                <rect x="44" y="20" width="8" height="1" fill="var(--color-natural-400)" opacity="0.6"/>
                <rect x="44" y="22" width="15" height="1" fill="var(--color-sage-400)" opacity="0.5"/>
                <rect x="44" y="24" width="10" height="1" fill="var(--color-human-400)" opacity="0.6"/>
                <rect x="44" y="26" width="18" height="1" fill="var(--color-digital-400)" opacity="0.5"/>
                <rect x="50" y="36" width="10" height="6" fill="var(--color-charcoal-400)"/>
                <rect x="45" y="42" width="20" height="2" rx="1" fill="var(--color-charcoal-300)"/>
              </svg>
              <p class="mt-4 font-[var(--font-mono)] text-xs text-ivory-300/50">// fotografía próximamente</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Text (2 cols) -->
      <div class="lg:col-span-2" data-animate="fade-up">
        <span class="dev-annotation mb-2">// section: brand-story</span>
        <h2 class="mb-6 text-[length:var(--text-h2)] font-semibold leading-tight text-charcoal-600">
          Donde lo digital se encuentra con lo natural
        </h2>
        <p class="mb-6 text-[length:var(--text-body)] font-light leading-relaxed text-charcoal-300">
          Tecleados nace de una idea simple pero profunda: que la tecnología puede sentirse
          viva. Cada teclado que creamos fusiona la nostalgia digital de la era 8-bit con la
          calidez de las maderas nativas argentinas y el cuidado artesanal de manos humanas.
        </p>
        <p class="mb-8 text-[length:var(--text-body)] font-light leading-relaxed text-charcoal-300">
          No hacemos periféricos. Hacemos piezas de autor que cuentan una historia —
          la historia de un bosque patagónico, de un taller en Buenos Aires, y de la persona
          que elige crear con algo único.
        </p>
        <p class="font-[var(--font-mono)] text-[length:var(--text-mono-sm)] text-sage-400">
          // compiled: buenos aires, argentina
        </p>
      </div>
    </div>
  </div>
</section>
