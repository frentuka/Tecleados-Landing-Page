---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import BrandStorySection from '../components/sections/BrandStorySection.astro';
import PillarsSection from '../components/sections/PillarsSection.astro';
import ProductShowcase from '../components/sections/ProductShowcase.astro';
import ProcessSection from '../components/sections/ProcessSection.astro';
import WoodGallery from '../components/sections/WoodGallery.astro';
import DevModeSection from '../components/sections/DevModeSection.astro';
import CommunitySection from '../components/sections/CommunitySection.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Navigation />
  <main>
    <HeroSection />
    <BrandStorySection />
    <PillarsSection />
    <ProductShowcase />
    <ProcessSection />
    <WoodGallery />
    <DevModeSection />
    <CommunitySection />
    <CtaSection />
  </main>
  <Footer />
</BaseLayout>
