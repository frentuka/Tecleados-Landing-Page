---
import '../styles/global.css';
import WoodGrainBackground from '../components/WoodGrainBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tecleados — Teclados Artesanales Argentinos',
  description = 'Teclados mecánicos artesanales que fusionan lo digital, lo natural y lo humano. Hechos a mano en Argentina con maderas nativas.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/Poppins-SemiBold.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Apply saved theme + bg color before render to prevent flash -->
    <script is:inline>
      (function(){
        var t=localStorage.getItem('tecleados-theme')||'dark';
        document.documentElement.setAttribute('data-theme',t);
        document.documentElement.style.backgroundColor=t==='light'?'rgb(220,205,183)':'rgb(22,14,7)';
      })();
    </script>
  </head>
  <body>
    <WoodGrainBackground />
    <slot />
    <script>
      import { initViewEngine } from '../scripts/view-engine';
      import { initWoodGrainBackground } from '../scripts/wood-grain-bg';
      initViewEngine();
      initWoodGrainBackground();
    </script>
  </body>
</html>
